# ========================================
# Tortrose Backend - Environment Variables
# ========================================
# Copy this file to .env and fill in the values

# ---------- Core ----------
NODE_ENV=production
PORT=5000

# ---------- Database ----------
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ---------- Auth ----------
JWT_SECRET=your_jwt_secret_here

# ---------- Frontend URL (for CORS & email links) ----------
FRONTEND_URL=https://www.tortrose.com

# ---------- Google OAuth ----------
clientID=your_google_client_id
clientSecret=your_google_client_secret
GOOGLE_CALLBACK_URL=https://your-heroku-app.herokuapp.com/api/auth/google/callback

# ---------- Stripe ----------
STRIPE_SECRET_KEY=sk_live_or_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ---------- Cloudinary ----------
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ---------- Brevo (Email) ----------
BREVO_API_KEY=xkeysib-xxx
BREVO_SENDER_NAME=Tortrose
BREVO_SENDER_EMAIL=noreply@tortrose.com

# ---------- Optional ----------
# HF_API_KEY=hf_xxx
# TRUST_PROXY_HOPS=1
