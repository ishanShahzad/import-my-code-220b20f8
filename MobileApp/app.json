{
  "expo": {
    "name": "Tortrose — Trusted Marketplace",
    "slug": "tortrose",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "tortrose",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "description": "Tortrose is a modern marketplace built on trust. Shop from verified independent sellers, discover unique products, and enjoy a seamless shopping experience with secure payments, real-time order tracking, and multi-currency support.",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6366f1"
      },
      "package": "com.tortrose.app",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "tortrose.com",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tortrose.app",
      "buildNumber": "1",
      "associatedDomains": [
        "applinks:tortrose.com"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "Tortrose needs camera access to let you take product photos.",
        "NSPhotoLibraryUsageDescription": "Tortrose needs photo library access to let you upload product images."
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "Tortrose"
        }
      ],
      "expo-web-browser",
      [
        "@sentry/react-native/expo",
        {
          "organization": "tortrose",
          "project": "tortrose-mobile"
        }
      ]
    ],
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "locales": {
      "en": "./locales/en.json"
    },
    "primaryColor": "#6366f1"
  }
}
